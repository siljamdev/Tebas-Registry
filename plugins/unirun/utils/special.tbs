import stdlib;
import tebas;
import tebasplugin;

export function trySpecialRun(file){
	if(getPathExtension(file).upper() == ".HTML"){
		return tebasplugin::runProcess(tebasplugin::getResource("browserPath"), "", file);
	}
}

