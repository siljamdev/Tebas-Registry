import stdlib;
import tebas;
import tebasplugin;

if !tebasplugin::fileExists("runnables.conf"){
	tebasplugin::fileWrite("runnables.conf", tebasplugin::getResource("runnables"));
}

if !tebasplugin::fileExists("debuggables.conf"){
	tebasplugin::fileWrite("debuggables.conf", tebasplugin::getResource("debuggables"));
}

if !tebasplugin::fileExists("buildables.conf"){
	tebasplugin::fileWrite("buildables.conf", tebasplugin::getResource("buildables"));
}
