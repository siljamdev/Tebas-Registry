import stdlib;
import stdnum;
import tebas;
import tebasproject;
import tebasplugin;
import "utils.utils";
import "utils.remotes";

if args.length != 1{
	error("Expected 1 argument: 'name'");
	exit;
}

exitIfNotInit();

if existsRemote(args.0){
	tebasproject::runProcess(tebasplugin::getResource("gitPath"), "", ["remote", "remove", args.0]);
}else{
	error("Remote does not exists: '" + args.0 + "'");
}
