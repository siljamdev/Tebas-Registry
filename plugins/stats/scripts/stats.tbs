import stdlib;
import stdnum;
import tebas;
import tebasproject;

if args.length != 0{
	error("Expected 0 arguments");
	exit;
}

tab lines = getProperty("stats.codeLines");

if(lines.isNum()){
	print("Lines of code in local project: " + lines);
}else{
	print("Looks like there is no lines of code in this project...");
}

tebasproject::runScript("stats", []);
