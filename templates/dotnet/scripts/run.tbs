import stdlib;
import tebas;
import tebasproject;
import tebastemplate;
import "scripts.build";

if build(){
	if tebastemplate::getResource("runDetached") == "true"{
		tebasproject::runProcessDetached(tebastemplate::getResource("dotnetPath"), "", ["run"]);
	}else{
		tebasproject::runProcess(tebastemplate::getResource("dotnetPath"), "", ["run"]);
	}
}
