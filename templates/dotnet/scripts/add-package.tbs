import stdlib;
import tebas;
import tebasproject;
import tebastemplate;

if args.length == 1{
	tebasproject::runProcess(tebastemplate::getResource("dotnetPath"), "", ["add", "package", args.0]);
}else if args.length == 2{
	tebasproject::runProcess(tebastemplate::getResource("dotnetPath"), "", ["add", "package", args.0, "--version", args.1]);
}else{
	error("Expected 1 or 2 arguments: 'package', 'version'");
	exit;
}
