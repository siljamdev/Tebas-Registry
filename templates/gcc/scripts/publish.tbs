import stdlib;
import tebas;
import tebasproject;
import tebastemplate;
import "scripts.build";

if args.length != 1{
	error("Expected 1 argument: 'version'");
	exit;
}

tebasproject::folderCreate("releases");

if tebasproject::folderExists("releases/" + args.0){
	tab ans = input("That version already exists. Do you want to override it? [Y/N] ").lower();
	if ans != "yes" & ans != "y"{
		exit;
	}
	tebasproject::folderDelete("releases/" + args.0);
}

buildPublish(args.0);
