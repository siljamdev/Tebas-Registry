import stdlib;
import stdnum;
import tebas;
import tebasproject;
import tebastemplate;

build();

export function build(){
	tab files = tebasproject::folderListChildFiles("src", "*.c");
	
	tab out = "bin/" + tebasproject::getName();
	tab exitCode = tebasproject::runProcess(tebastemplate::getResource("gccPath"), "", files + "-Iinclude" + "-o" + out^);
	
	tebasproject::setResource("timesBuilt", stdnum::sum(tebasproject::getResource("timesBuilt"), "1"));
	
	return exitCode == "0";
}

export function buildDebug(){
	tab files = tebasproject::folderListChildFiles("src", "*.c");
	
	tab out = "bin/" + tebasproject::getName();
	tab exitCode = tebasproject::runProcess(tebastemplate::getResource("gccPath"), "", files + "-Iinclude" + "-g" + "-o" + out^);
	
	tebasproject::setResource("timesBuilt", stdnum::sum(tebasproject::getResource("timesBuilt"), "1"));
	
	return exitCode == "0";
}

export function buildPublish(version){
	tab files = tebasproject::folderListChildFiles("src", "*.c");
	
	tebasproject::folderCreate("releases/" + version);
	
	tab out = "releases/" + version + "/" + tebasproject::getName();
	tebasproject::runProcess(tebastemplate::getResource("gccPath"), "", files + "-Iinclude" + "-o" + out^);
	
	tebasproject::setResource("timesBuilt", stdnum::sum(tebasproject::getResource("timesBuilt"), "1"));
}
