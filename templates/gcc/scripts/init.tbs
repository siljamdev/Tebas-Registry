import stdlib;
import tebas;
import tebasproject;
import tebastemplate;

tebasproject::folderCreate("src");
tebasproject::folderCreate("include");
tebasproject::folderCreate("bin");
tebasproject::folderCreate("releases");

tab files = tebasproject::folderListChildFiles("src", "*.c");
if files.length <= 0{
	if !tebasproject::fileExists("src/main.c"){
		tebasproject::fileWrite("src/main.c", tebastemplate::getResource("program"));
	}
}

tebasproject::setResource("timesBuilt", "0");
