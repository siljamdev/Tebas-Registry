import stdlib;
import tebas;
import tebasproject;
import tebastemplate;

tab files = tebasproject::folderListFiles("", "*.c");
if files.length <= 0{
	if(!tebasproject::fileExists("main.c")){
		tebasproject::fileWrite("main.c", tebastemplate::getResource("program"));
	}
}

tebasproject::folderCreate("bin");
tebasproject::folderCreate("releases");
